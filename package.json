{
  "name": "esp32-drop-dashboard",
  "version": "1.0.0",
  "description": "Professional ESP32 Drop Detection Dashboard",
  "private": true,
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "nodemailer": "^8.0.4",
    "otp-generator": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.7.2",
    "three": "^0.183.2"
  },
  "scripts": {
    "server": "python hi.py",
    "dev": "concurrently \"npm run server\" \"npm start\"",
    "start": "node --max_old_space_size=6144 ./node_modules/react-scripts/bin/react-scripts.js start",
    "build": "node --max_old_space_size=6144 ./node_modules/react-scripts/bin/react-scripts.js build",
    "test": "node --max_old_space_size=6144 ./node_modules/react-scripts/bin/react-scripts.js test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:5000"
}
